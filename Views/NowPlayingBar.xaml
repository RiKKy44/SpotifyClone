<UserControl x:Class="GLab6.Views.NowPlayingBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GLab6.Converters">

    <UserControl.Resources>
        <conv:BytesToImageConverter x:Key="BytesToImageConverter"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource PrimaryBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0">
            <Grid Width="40" Height="40" Background="#444">
                <TextBlock Text="♪" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#888"/>
                <Border CornerRadius="4">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding CurrentSong.CoverData, Converter={StaticResource BytesToImageConverter}}" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
            </Grid>
            <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                <TextBlock Text="{Binding CurrentSong.Title, TargetNullValue='Nothing playing'}" Foreground="White" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis" MaxWidth="140"/>
                <TextBlock Text="{Binding CurrentSong.Artist}" Foreground="#AAA" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="140"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Column="1" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                <Button Content="⏮" Command="{Binding PreviousCommand}" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Margin="0,0,15,0" Cursor="Hand"/>
                <Button Command="{Binding PlayPauseCommand}" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="20" Margin="0,0,15,0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="▶"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Content" Value="⏸"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="⏭" Command="{Binding NextCommand}" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Cursor="Hand"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Position, StringFormat={}{0:m\\:ss}}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="{Binding DurationSeconds}" Value="{Binding PositionSeconds, Mode=TwoWay}" VerticalAlignment="Center" IsMoveToPointEnabled="True"/>
                <TextBlock Grid.Column="2" Text="{Binding RemainingTime, StringFormat=-{}{0:m\\:ss}}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>
        </Grid>

        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
            <TextBlock Text="🔊" Foreground="#AAA" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <Slider Minimum="0" Maximum="1" Value="{Binding Volume}" Width="100" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>