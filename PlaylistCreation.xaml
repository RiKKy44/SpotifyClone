<Window x:Class="GLab6.PlaylistCreation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Playlist" 
        Height="220" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,15,0">
            <Grid Width="80" Height="80" Background="#DDDDDD">
                <TextBlock Text="No Cover" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555"/>
                <Image Name="servicePhoto" Stretch="UniformToFill" Width="80" Height="80"/>
            </Grid>
            <Button Content="Browse cover..." Margin="0,10,0,0" Padding="5,2" Click="Browse"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Label Content="Name" Padding="0,0,0,2"/>
                <TextBox Name="PlaylistNameTextBox" Padding="2" TextChanged="PlaylistNameTextBox_TextChanged"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="60" Height="25" Margin="0,0,10,0" Click="Cancel"/>
                <Button Name="SaveBtn" Content="Save" Width="60" Height="25" 
                        Background="{StaticResource AccentBrush}" Foreground="White" BorderBrush="Transparent"
                        IsEnabled="False" Click="Save"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>