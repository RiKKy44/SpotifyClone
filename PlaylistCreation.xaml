<Window x:Class="GLab6.PlaylistCreation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GLab6.Converters"
        Title="Playlist Editor" Height="220" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BytesToImageConverter x:Key="BytesToImageConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,15,0">
            <Grid Width="80" Height="80" Background="#DDDDDD">
                <TextBlock Text="No Cover" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555"/>
                <Border CornerRadius="4">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding CoverData, Converter={StaticResource BytesToImageConverter}}" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
            </Grid>
            <Button Content="Browse cover..." Command="{Binding BrowseCoverCommand}" Margin="0,10,0,0" Padding="5,2" Cursor="Hand"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Label Content="Name" Padding="0,0,0,2"/>
                <TextBox Text="{Binding PlaylistName, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Command="{Binding CancelCommand}" Width="60" Height="25" Margin="0,0,10,0" Cursor="Hand"/>
                <Button Content="Save" Command="{Binding SaveCommand}" Width="60" Height="25" Background="#E91E63" Foreground="White" BorderBrush="Transparent" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>