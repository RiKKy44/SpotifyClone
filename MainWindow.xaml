<Window x:Class="GLab6.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GLab6"
        mc:Ignorable="d"
        Title="Musica" 
        Height="600" Width="1000" 
        MinHeight="480" MinWidth="800"
        Icon="/Resources/vinyl.ico">

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#F0F0F0">
            <MenuItem Header="Library">
                <MenuItem Header="New..." Click="CreateLibrary"/>
                <MenuItem Header="Open..." Click="OpenLibrary"/>
                <MenuItem Header="Save" Click="SaveLibrary" InputGestureText="Ctrl+S"/>
            </MenuItem>
            <MenuItem Header="Songs">
                <MenuItem Header="Import..." Click="SongsImport"/>
                <MenuItem Header="Edit..." Click="SongsEdit"/>
                <MenuItem Header="Delete" Click="SongsDelete" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="Playlist">
                <MenuItem Header="New..." Click="NewPlaylist"/>
            </MenuItem>
        </Menu>

        <Grid DockPanel.Dock="Bottom" Height="56" Background="{StaticResource PrimaryBrush}">
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Name="Sidebar" Background="{StaticResource SidebarGradient}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="15,0">
                    <Button DockPanel.Dock="Right" Content="+" Width="24" Height="24" VerticalAlignment="Center" Click="NewPlaylist" Background="Transparent" Foreground="White" BorderBrush="White" Cursor="Hand"/>
                    <TextBlock Text="PLAYLISTS" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>
                </DockPanel>

                <ListBox Grid.Row="1" ItemsSource="{Binding Playlists}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Name="Border" Padding="{TemplateBinding Padding}" Background="Transparent" CornerRadius="4" Margin="5,2">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Cursor="Hand">
                                <Grid Width="36" Height="36">
                                    <Rectangle Fill="#555555" RadiusX="4" RadiusY="4"/>
                                </Grid>
                                <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="14"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <DataGrid Grid.Column="1" ItemsSource="{Binding Songs}" 
                      AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionMode="Single" SelectionUnit="FullRow"
                      CanUserAddRows="False" HeadersVisibility="Column"
                      GridLinesVisibility="None" RowHeight="35"
                      AlternatingRowBackground="#F9F9F9" BorderThickness="1,0,0,0" BorderBrush="#E0E0E0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="40" ElementStyle="{StaticResource {x:Type TextBlock}}"/>
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*"/>
                    <DataGridTextColumn Header="Artist" Binding="{Binding Artist}" Width="2*"/>
                    <DataGridTextColumn Header="Album" Binding="{Binding Album}" Width="2*"/>
                    <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="80"/>
                    <DataGridTextColumn Header="Duration" Binding="{Binding Duration, StringFormat={}{0:m\\:ss}}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>