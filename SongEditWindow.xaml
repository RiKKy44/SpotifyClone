<Window x:Class="GLab6.SongEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GLab6.Converters"
        Title="Edit Song Metadata" Height="380" Width="460"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BytesToImageConverter x:Key="BytesToImageConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <Grid Width="120" Height="120" Background="#DDDDDD">
                <TextBlock Text="No Cover" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555"/>
                <Border CornerRadius="4">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding CoverData, Converter={StaticResource BytesToImageConverter}}" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
            </Grid>
            <Button Content="Browse cover..." Command="{Binding BrowseCoverCommand}" Margin="0,10,0,0" Padding="5,4" Cursor="Hand"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Title" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Padding="4"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <TextBlock Text="Artist" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Artist, UpdateSourceTrigger=PropertyChanged}" Padding="4"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <TextBlock Text="Album" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Album, UpdateSourceTrigger=PropertyChanged}" Padding="4"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,10">
                <TextBlock Text="Genre" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}" Padding="4"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,10">
                <TextBlock Text="Year" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}" Padding="4"/>
            </StackPanel>

            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Command="{Binding CancelCommand}" Width="70" Height="30" Margin="0,0,10,0" Cursor="Hand"/>
                <Button Content="Save" Command="{Binding SaveCommand}" Width="70" Height="30" Background="#E91E63" Foreground="White" BorderBrush="Transparent" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>